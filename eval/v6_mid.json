  "segments": [
    {
      "start": 0.0,
      "end": 2.54,
      "text": "后来的婴儿换成了成年人了"
    },
    {
      "start": 2.54,
      "end": 6.22,
      "text": "第二个是宣传,提高婴儿免医力"
    },
    {
      "start": 6.22,
      "end": 9.78,
      "text": "这次改了,是修复长道的功能"
    },
    {
      "start": 9.78,
      "end": 10.36,
      "text": "拽老"
    },
    {
      "start": 10.96,
      "end": 13.38,
      "text": "第三,也是渠道也换了"
    },
    {
      "start": 13.38,
      "end": 16.72,
      "text": "以前是威伤,思愈,做直销"
    },
    {
      "start": 17.44,
      "end": 19.84,
      "text": "现在是直播室靠主播带货"
    },
    {
      "start": 19.84,
      "end": 22.44,
      "text": "说了一下,牛处乳的科学证据"
    },
    {
      "start": 22.44,
      "end": 24.8,
      "text": "目前来看,还是有一些研究的"
    },
    {
      "start": 24.8,
      "end": 28.58,
      "text": "主要是集中在运动员高强度训练之后"
    },
    {
      "start": 29.14,
      "end": 32.14,
      "text": "他的长道修复的特定的场景"
    },
    {
      "start": 32.14,
      "end": 35.24,
      "text": "在这个条件下,牛处乳确实有一定效"
    }
  ]
