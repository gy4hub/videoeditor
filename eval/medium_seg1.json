  "segments": [
    {
      "start": 2.0,
      "end": 6.34,
      "text": "还记得当年那个鸿鸡一时的婴儿保健品叫牛出乳吗"
    },
    {
      "start": 6.34,
      "end": 7.74,
      "text": "现在它又杀回来了"
    },
    {
      "start": 7.74,
      "end": 9.92,
      "text": "咱们看看这到底是怎么回事"
    },
    {
      "start": 9.92,
      "end": 11.54,
      "text": "先说牛出乳啊"
    },
    {
      "start": 11.54,
      "end": 13.36,
      "text": "当年可是号称奶中黄金"
    },
    {
      "start": 13.36,
      "end": 16.16,
      "text": "还有大量的免疫因子啊生长因子"
    },
    {
      "start": 16.16,
      "end": 18.1,
      "text": "可以提高孩子的免疫力"
    },
    {
      "start": 18.1,
      "end": 20.58,
      "text": "当年的宣传呢那真是铺天盖地"
    },
    {
      "start": 20.58,
      "end": 22.72,
      "text": "结果呢2012年"
    },
    {
      "start": 22.72,
      "end": 24.24,
      "text": "卫生部的一纸禁令"
    },
    {
      "start": 24.24,
      "end": 25.42,
      "text": "应幼儿产品"
    },
    {
      "start": 25.42,
      "end": 26.82,
      "text": "禁止添加牛出乳"
    },
    {
      "start": 26.82,
      "end": 29.4,
      "text": "让这个概念呢瞬间杀了车"
    },
    {
      "start": 29.4,
      "end": 30.6,
      "text": "当时的理由呢"
    },
    {
      "start": 30.6,
      "end": 31.68,
      "text": "其实非常合理"
    },
    {
      "start": 31.68,
      "end": 33.5,
      "text": "因为啊所谓的牛出乳啊"
    },
    {
      "start": 33.5,
      "end": 37.1,
      "text": "是牛刚好产载的7天内的乳汁"
    },
    {
      "start": 37.1,
      "end": 39.94,
      "text": "在工业化的这个过程中呢"
    },
    {
      "start": 39.94,
      "end": 42.78,
      "text": "收集质量控制都是非常困难的"
    },
    {
      "start": 42.78,
      "end": 44.46,
      "text": "也没什么标准"
    },
    {
      "start": 44.46,
      "end": 44.92,
      "text": "所以呢"
    },
    {
      "start": 44.92,
      "end": 46.64,
      "text": "很多的不良商家"
    },
    {
      "start": 46.64,
      "end": 47.68,
      "text": "以刺冲好啊"
    },
    {
      "start": 47.68,
      "end": 48.72,
      "text": "混水摸鱼啊"
    },
    {
      "start": 48.72,
      "end": 50.44,
      "text": "造成了很多的社会乱象"
    }
  ]
}