  "segments": [
    {
      "start": 165.78,
      "end": 170.14,
      "text": "现在牛出乳这套市场营销的配方也不是专属的"
    },
    {
      "start": 170.14,
      "end": 174.46,
      "text": "这是所有的超级网红食品的共同的剧本"
    },
    {
      "start": 174.46,
      "end": 176.38,
      "text": "找一个人人都有的问题"
    },
    {
      "start": 177.1,
      "end": 179.1,
      "text": "贴一个科学名词"
    },
    {
      "start": 180.06,
      "end": 181.66,
      "text": "换受众换渠道"
    },
    {
      "start": 181.66,
      "end": 182.4,
      "text": "制造焦虑"
    },
    {
      "start": 182.4,
      "end": 183.36,
      "text": "卖货变现"
    },
    {
      "start": 183.36,
      "end": 186.6,
      "text": "认清这个结构比专门去研究某个成分"
    },
    {
      "start": 186.6,
      "end": 188.42,
      "text": "我觉得省事多了"
    },
    {
      "start": 188.42,
      "end": 191.44,
      "text": "所以对于牛出乳你怎么看"
    },
    {
      "start": 191.44,
      "end": 192.7,
      "text": "我是天爸"
    },
    {
      "start": 192.7,
      "end": 194.34,
      "text": "咱们今天就聊到这"
    },
    {
      "start": 194.34,
      "end": 195.34,
      "text": "下次再见"
    }
  ]
}