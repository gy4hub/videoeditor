          "word_end_idx": 30,
          "confidence": 0.8,
          "transcript_text": "现在他又杀回来了咱们看看这",
          "keep": true,
          "reason": "matched"
        }
      ]
    },
    {
      "id": 2,
      "script_text": "先说牛初乳当年号称是奶中黄金，含有大量的免疫因子和生长因子，可以提高孩子免疫力。",
      "matched": true,
      "is_repeat": false,
