          "word_start_idx": 45,
          "word_end_idx": 65,
          "confidence": 0.2545,
          "transcript_text": "称乃中黄金还有大量的免疫阴子、生长阴子可以提高孩子",
          "keep": true,
          "reason": "matched"
        }
      ]
    },
    {
      "id": 3,
