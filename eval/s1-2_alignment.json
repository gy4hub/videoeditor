          "word_start_idx": 70,
          "word_end_idx": 81,
          "confidence": 0.5263,
          "transcript_text": "当年的宣传能那真是铺天盖地",
          "keep": true,
          "reason": "matched"
        }
      ]
    },
    {
      "id": 4,
      "script_text": "结果到2012年卫生部一纸禁令，婴幼儿产品禁止添加牛初乳，让这个概念瞬间刹车。",
      "matched": true,
      "is_repeat": false,
