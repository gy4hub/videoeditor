          "end_tc": "00:04.260",
          "word_start_idx": 0,
          "word_end_idx": 12,
          "confidence": 0.3333,
          "transcript_text": "还记得当年那个红鸡翼石的嬰儿",
          "keep": true,
          "reason": "matched"
        }
      ]
    },
    {
      "id": 1,
      "script_text": "现在他又杀回来了，咱们看看这是怎么回事。",
