  "segments": [
    {
      "start": 2.0,
      "end": 5.9,
      "text": "还记得当年那个红鸡一时的婴儿宝剑品叫牛出乳吗"
    },
    {
      "start": 5.9,
      "end": 7.56,
      "text": "现在它又杀回来了"
    },
    {
      "start": 7.56,
      "end": 9.52,
      "text": "咱们看看这到底是怎么回事"
    },
    {
      "start": 10.04,
      "end": 11.24,
      "text": "先说牛出乳啊"
    },
    {
      "start": 11.24,
      "end": 13.14,
      "text": "当年可是号称奶中黄金"
    },
    {
      "start": 13.14,
      "end": 15.04,
      "text": "还有大量的免疫因子啊"
    },
    {
      "start": 15.04,
      "end": 15.88,
      "text": "生长因子"
    },
    {
      "start": 15.88,
      "end": 17.74,
      "text": "可以提高孩子的免疫力"
    },
    {
      "start": 17.74,
      "end": 20.14,
      "text": "当年的宣传呢那真是铺天盖地"
    },
    {
      "start": 20.54,
      "end": 21.38,
      "text": "结果呢"
    },
    {
      "start": 21.38,
      "end": 23.94,
      "text": "2012年卫生部的一纸禁令"
    },
    {
      "start": 23.94,
      "end": 25.1,
      "text": "应幼儿产品"
    },
    {
      "start": 25.1,
      "end": 26.7,
      "text": "禁止添加牛出乳"
    },
    {
      "start": 26.7,
      "end": 29.2,
      "text": "让这个概念瞬间杀了车"
    },
    {
      "start": 29.2,
      "end": 30.38,
      "text": "当时的理由呢"
    },
    {
      "start": 30.38,
      "end": 31.54,
      "text": "其实非常合理"
    },
    {
      "start": 31.54,
      "end": 33.12,
      "text": "因为啊所谓的牛出乳啊"
    },
    {
      "start": 33.12,
      "end": 36.76,
      "text": "是牛刚好产载的七天内的乳汁"
    },
    {
      "start": 36.76,
      "end": 39.62,
      "text": "在工业化的这个过程中呢"
    },
    {
      "start": 39.62,
      "end": 42.46,
      "text": "收集质量控制都是非常困难的"
    },
    {
      "start": 42.46,
      "end": 43.98,
      "text": "也没什么标准"
    },
    {
      "start": 43.98,
      "end": 46.38,
      "text": "所以呢很多的不良商家"
    },
    {
      "start": 46.38,
      "end": 47.5,
      "text": "一次冲好啊"
    },
    {
      "start": 47.5,
      "end": 48.36,
      "text": "混水摸鱼啊"
    },
    {
      "start": 48.36,
      "end": 50.44,
      "text": "造成了很多的社会乱象"
    }
  ]
}