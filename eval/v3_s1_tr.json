  "segments": [
    {
      "start": 0.02,
      "end": 3.88,
      "text": "还记得当年那个红鸡一时的婴儿宝剑品叫牛出乳吗"
    },
    {
      "start": 3.88,
      "end": 5.54,
      "text": "现在它又杀回来了"
    },
    {
      "start": 5.54,
      "end": 7.52,
      "text": "咱们看看这到底是怎么回事"
    },
    {
      "start": 7.52,
      "end": 8.76,
      "text": "先说牛出乳啊"
    },
    {
      "start": 8.76,
      "end": 10.76,
      "text": "当年可是号称奶中黄金"
    },
    {
      "start": 10.76,
      "end": 12.58,
      "text": "还有大量的免疫因子啊"
    },
    {
      "start": 12.58,
      "end": 13.38,
      "text": "生长因子"
    },
    {
      "start": 13.38,
      "end": 15.2,
      "text": "可以提高孩子的免疫力"
    },
    {
      "start": 15.2,
      "end": 17.62,
      "text": "当年的宣传那真是铺天盖地"
    },
    {
      "start": 18.02,
      "end": 18.82,
      "text": "结果呢"
    },
    {
      "start": 18.82,
      "end": 19.84,
      "text": "2012年"
    },
    {
      "start": 19.84,
      "end": 21.4,
      "text": "卫生部的一纸禁令"
    },
    {
      "start": 21.4,
      "end": 22.56,
      "text": "应幼儿产品"
    },
    {
      "start": 22.56,
      "end": 24.16,
      "text": "禁止添加牛出乳"
    },
    {
      "start": 24.16,
      "end": 26.2,
      "text": "让这个概念瞬间杀了车"
    },
    {
      "start": 26.7,
      "end": 27.82,
      "text": "当时的理由呢"
    },
    {
      "start": 27.82,
      "end": 28.96,
      "text": "其实非常合理"
    },
    {
      "start": 28.96,
      "end": 29.46,
      "text": "因为啊"
    },
    {
      "start": 29.46,
      "end": 30.52,
      "text": "所谓的牛出乳啊"
    },
    {
      "start": 30.52,
      "end": 33.02,
      "text": "是牛刚好产载的"
    },
    {
      "start": 33.02,
      "end": 34.1,
      "text": "七天内的乳汁"
    },
    {
      "start": 34.1,
      "end": 37.04,
      "text": "在工业化的这个过程中呢"
    },
    {
      "start": 37.04,
      "end": 39.88,
      "text": "收集质量控制都是非常困难的"
    },
    {
      "start": 39.88,
      "end": 41.38,
      "text": "也没什么标准"
    },
    {
      "start": 41.38,
      "end": 42.24,
      "text": "所以呢"
    },
    {
      "start": 42.24,
      "end": 43.74,
      "text": "很多的不良商家"
    },
    {
      "start": 43.74,
      "end": 44.9,
      "text": "一次冲好啊"
    },
    {
      "start": 44.9,
      "end": 45.78,
      "text": "混水摸鱼啊"
    },
    {
      "start": 45.78,
      "end": 47.86,
      "text": "造成了很多的社会乱象"
    },
    {
      "start": 47.86,
      "end": 48.54,
      "text": "那这两年"
    },
    {
      "start": 48.54,
      "end": 49.62,
      "text": "牛出乳又回来了"
    },
    {
      "start": 49.62,
      "end": 50.84,
      "text": "但是这次啊"
    },
    {
      "start": 50.84,
      "end": 51.84,
      "text": "他这个火啊"
    },
    {
      "start": 51.84,
      "end": 54.02,
      "text": "是从美国烧到国内的"
    },
    {
      "start": 54.02,
      "end": 54.98,
      "text": "美国这两年"
    }
  ]
}