          "word_start_idx": 47,
          "word_end_idx": 67,
          "confidence": 0.4727,
          "transcript_text": "奶中黄金还有大量的免疫因子啊生长因子可以提高孩子",
          "keep": true,
          "reason": "matched"
        }
      ]
    },
    {
