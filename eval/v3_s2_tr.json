  "segments": [
    {
      "start": 55.0,
      "end": 59.64,
      "text": "像年牛出乳产品从原来的61万美元市场份额"
    },
    {
      "start": 59.64,
      "end": 62.0,
      "text": "一下子涨到了1900万美元"
    },
    {
      "start": 62.38,
      "end": 63.8,
      "text": "整整涨了300倍"
    },
    {
      "start": 64.24,
      "end": 65.7,
      "text": "这一次有什么不一样的"
    },
    {
      "start": 65.7,
      "end": 67.16,
      "text": "我总结有三个变化"
    },
    {
      "start": 67.16,
      "end": 69.22,
      "text": "这第一个就是对象变了"
    },
    {
      "start": 69.22,
      "end": 72.26,
      "text": "从原来的婴儿换成了成年人了"
    },
    {
      "start": 72.26,
      "end": 74.18,
      "text": "第二个是宣传"
    },
    {
      "start": 74.18,
      "end": 75.74,
      "text": "提高婴儿免一例"
    },
    {
      "start": 75.74,
      "end": 79.64,
      "text": "这次改了是修复长道的功能"
    },
    {
      "start": 79.64,
      "end": 83.36,
      "text": "改善皮肤和抗"
    },
    {
      "start": 83.36,
      "end": 85.44,
      "text": "改善皮肤和抗衰老"
    },
    {
      "start": 85.44,
      "end": 88.3,
      "text": "第三也是渠道也换了"
    },
    {
      "start": 88.3,
      "end": 94.46,
      "text": "以前是微商群私域做直销"
    },
    {
      "start": 95.12,
      "end": 97.56,
      "text": "现在是直播市靠主播带货"
    },
    {
      "start": 97.56,
      "end": 99.76,
      "text": "揪了一下牛出乳的科学证据"
    },
    {
      "start": 99.76,
      "end": 102.14,
      "text": "目前来看还是有一些研究的"
    },
    {
      "start": 102.14,
      "end": 105.92,
      "text": "主要是集中在运动员高强度训练之后"
    },
    {
      "start": 105.92,
      "end": 109.18,
      "text": "它的长道修复的这些特定的场景"
    },
    {
      "start": 109.18,
      "end": 109.92,
      "text": "在这个"
    }
  ]
}