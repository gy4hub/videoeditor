{
  "offset": 110.0,
  "segments": [
    {
      "start": 110.0,
      "end": 112.78,
      "text": "条件下牛出卤确实有一定效果"
    },
    {
      "start": 112.78,
      "end": 115.16,
      "text": "但是针对于普通的成年人"
    },
    {
      "start": 115.16,
      "end": 117.3,
      "text": "像做皮肤抗衰"
    },
    {
      "start": 117.3,
      "end": 121.8,
      "text": "日常免疫这些所谓的电商里面主要的卖点"
    },
    {
      "start": 122.36,
      "end": 126.06,
      "text": "暂时还没有经过大规模的随机对照实验"
    },
    {
      "start": 126.06,
      "end": 128.1,
      "text": "这一块几乎是空白的"
    },
    {
      "start": 128.1,
      "end": 130.04,
      "text": "这也难免像彭博社"
    },
    {
      "start": 130.04,
      "end": 132.08,
      "text": "今天2月份也做了一篇报道"
    },
    {
      "start": 132.08,
      "end": 136.0,
      "text": "说同样指出了目前牛出卤的这些科学证据"
    },
    {
      "start": 136.0,
      "end": 137.24,
      "text": "还是比较单薄"
    },
    {
      "start": 137.24,
      "end": 137.8,
      "text": "那现在"
    },
    {
      "start": 138.0,
      "end": 140.18,
      "text": "牛出乳这套市场营销的配方"
    },
    {
      "start": 140.18,
      "end": 141.76,
      "text": "它也不是专属的"
    },
    {
      "start": 141.76,
      "end": 145.26,
      "text": "这是所谓的所有的超级网红食品的"
    },
    {
      "start": 145.26,
      "end": 146.08,
      "text": "共同的剧本"
    },
    {
      "start": 146.08,
      "end": 148.04,
      "text": "找一个人人都有的问题"
    },
    {
      "start": 148.04,
      "end": 148.84,
      "text": "是吧"
    },
    {
      "start": 148.84,
      "end": 150.72,
      "text": "贴一个科学名词"
    },
    {
      "start": 150.72,
      "end": 153.1,
      "text": "换受众换渠道制造焦虑"
    },
    {
      "start": 153.1,
      "end": 154.0,
      "text": "卖货变现"
    },
    {
      "start": 154.0,
      "end": 155.38,
      "text": "认清这个结构"
    },
    {
      "start": 155.38,
      "end": 157.28,
      "text": "比专门去研究某个成分"
    },
    {
      "start": 157.28,
      "end": 158.94,
      "text": "我觉得省事多了"
    },
    {
      "start": 158.94,
      "end": 161.36,
      "text": "所以对于牛出乳"
    },
    {
      "start": 161.36,
      "end": 162.36,
      "text": "你怎么看呢"
    },
    {
      "start": 162.36,
      "end": 163.38,
      "text": "我是天爸"
    },
    {
      "start": 163.38,
      "end": 165.02,
      "text": "咱们今天就聊到这"
    },
    {
      "start": 165.02,
      "end": 165.98,
      "text": "下次再见"
    }
  ]
}