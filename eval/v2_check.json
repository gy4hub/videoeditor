  "segments": [
    {
      "start": 0.0,
      "end": 1.92,
      "text": "换成了承烈人了"
    },
    {
      "start": 1.92,
      "end": 5.26,
      "text": "第二个是宣传提供免英尔免疫力"
    },
    {
      "start": 5.26,
      "end": 8.88,
      "text": "这次改了是修复长道的功能"
    },
    {
      "start": 8.88,
      "end": 10.82,
      "text": "改善皮肤和抗水了"
    },
    {
      "start": 10.82,
      "end": 13.38,
      "text": "第三也是取道也化了"
    },
    {
      "start": 13.38,
      "end": 18.38,
      "text": "以前是威商却思语"
    },
    {
      "start": 18.38,
      "end": 19.54,
      "text": "做直销"
    },
    {
      "start": 20.14,
      "end": 23.1,
      "text": "现在是直播是靠主播待户"
    },
    {
      "start": 23.26,
      "end": 24.84,
      "text": "我也研究了一下"
    },
    {
      "start": 24.84,
      "end": 26.22,
      "text": "牛处的科学证据"
    },
    {
      "start": 26.22,
      "end": 27.24,
      "text": "目前来看"
    },
    {
      "start": 27.24,
      "end": 28.6,
      "text": "还是有一些研究的"
    },
    {
      "start": 28.6,
      "end": 32.56,
      "text": "主要是集中在运动员高强度训练之后"
    },
    {
      "start": 32.56,
      "end": 35.84,
      "text": "它的这个长道修复的这些彻定的场景"
    },
    {
      "start": 35.84,
      "end": 37.2,
      "text": "在这个条件下"
    },
    {
      "start": 37.2,
      "end": 39.0,
      "text": "牛处入确实有一定效果"
    },
    {
      "start": 39.0,
      "end": 41.56,
      "text": "但是针对于普通的承烈人"
    },
    {
      "start": 41.56,
      "end": 44.78,
      "text": "像做皮膚、抗摔、日常免疫"
    },
    {
      "start": 44.78,
      "end": 48.46,
      "text": "这些所谓的电商里面主要的卖点"
    },
    {
      "start": 48.46,
      "end": 52.54,
      "text": "暂时还没有经过大规模的随机对照实验"
    },
    {
      "start": 52.54,
      "end": 54.72,
      "text": "这一块几乎是空白的"
    },
    {
      "start": 54.72,
      "end": 56.52,
      "text": "这也难免像彭博社"
    },
    {
      "start": 56.52,
      "end": 58.58,
      "text": "今天二月份也做了一篇报道"
    },
    {
      "start": 58.58,
      "end": 60.0,
      "text": "说同样指出了目前"
    },
    {
      "start": 60.0,
      "end": 62.28,
      "text": "牛处入的这些科学证据"
    },
    {
      "start": 62.28,
      "end": 64.08,
      "text": "还是比较单薄"
    },
    {
      "start": 65.22,
      "end": 67.94,
      "text": "现在牛处入这套市场营销的配方"
    },
    {
      "start": 67.94,
      "end": 69.98,
      "text": "它也不是专属的"
    }
  ]
}