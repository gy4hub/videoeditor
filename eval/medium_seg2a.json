  "segments": [
    {
      "start": 0.52,
      "end": 2.62,
      "text": "这两年牛畜乳又回来了"
    },
    {
      "start": 2.62,
      "end": 4.68,
      "text": "但是这次它这个火啊"
    },
    {
      "start": 4.68,
      "end": 7.22,
      "text": "是从美国烧到国内的"
    },
    {
      "start": 7.22,
      "end": 8.86,
      "text": "美国这两年牛畜乳产品"
    },
    {
      "start": 8.86,
      "end": 11.42,
      "text": "从原来的61万美元"
    },
    {
      "start": 11.42,
      "end": 13.06,
      "text": "市场份额啊"
    },
    {
      "start": 13.06,
      "end": 14.82,
      "text": "一下子涨到了1900万美元"
    },
    {
      "start": 14.82,
      "end": 16.92,
      "text": "整整涨了300倍"
    },
    {
      "start": 16.92,
      "end": 18.26,
      "text": "那这一次啊"
    },
    {
      "start": 18.26,
      "end": 19.9,
      "text": "有什么不一样的"
    },
    {
      "start": 20.42,
      "end": 22.04,
      "text": "那这一次有什么不一样的"
    },
    {
      "start": 22.04,
      "end": 23.76,
      "text": "我总结有三个变化"
    },
    {
      "start": 23.76,
      "end": 25.7,
      "text": "第一个就是对象变了"
    },
    {
      "start": 25.7,
      "end": 27.26,
      "text": "从原来的婴儿"
    },
    {
      "start": 27.26,
      "end": 28.6,
      "text": "换成了成年人了"
    }
  ]
